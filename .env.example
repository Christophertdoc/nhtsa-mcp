# HTTP timeouts (seconds)
HTTP_CONNECT_TIMEOUT=5.0
HTTP_READ_TIMEOUT=15.0
HTTP_TOTAL_TIMEOUT=20.0

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_MIN_SECONDS=1.0
RETRY_WAIT_MAX_SECONDS=10.0

# Concurrency
MAX_CONCURRENT_UPSTREAM_REQUESTS=20

# Rate limits
RATE_LIMIT_GLOBAL_PER_MINUTE=60
RATE_LIMIT_VIN_PER_MINUTE=10
RATE_LIMIT_DAILY_QUOTA=1000
RATE_LIMIT_ENABLED=true

# Output
INCLUDE_RAW_RESPONSE=false

# Bulk VIN (off by default)
BULK_VIN_ENABLED=false
BULK_VIN_MAX=5

# LLM (for CLI agent)
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_MODEL_ANTHROPIC=claude-opus-4-6
LLM_MODEL_OPENAI=gpt-4o
LLM_MAX_TOOL_ITERATIONS=10
